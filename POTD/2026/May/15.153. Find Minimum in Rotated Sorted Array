class Solution {
    public int findMin(int[] nums) {
        int l=0,h=nums.length-1;
        int ans=-1;
        while(l<=h){
            int m=l+(h-l)/2;
            if(nums[l]>nums[h]){
               if(nums[m]<=nums[h]){
                    ans=m;
                    h=m;
               }else{
                l=m+1;
               }
            }else{
                ans=m;
                h=m-1;
            }
        }
        return nums[ans];
    }
}
