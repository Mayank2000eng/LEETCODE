class Solution {
    public int minMoves(int[] nums, int limit) {
        int[] pair_sum=new int[2*limit+2];
        int[] pair_range=new int[2*limit+2];
        for(int i=0;i<nums.length/2;i++){
            int r=nums[i]+nums[nums.length-1-i];
            pair_sum[r]++;
            int min_p=Math.min(nums[i],nums[nums.length-1-i])+1;
            int max_p=Math.max(nums[i],nums[nums.length-1-i])+limit;
            pair_range[min_p]++;
            pair_range[max_p+1]--;
        }
        for(int i=1;i<pair_range.length;i++){
            pair_range[i]+=pair_range[i-1];
        }
        int min=Integer.MAX_VALUE;
        for(int i=0;i<pair_range.length;i++){
            int c=pair_range[i]-pair_sum[i];
            int c1=((nums.length/2-c)-pair_sum[i])*2;
            min=Math.min(min,c+c1);
        }
        return min;
    }
}
