class Solution {
    public boolean consecutiveSetBits(int n) {
        int flag=0;
        int c=0;
        while(n>0){
            if((n&1)==1) c++;
            else c=0;
            if(c>=2){
                if(flag==1) return false;
                else flag=1;
            }
            n=n>>1;
        }
        if(flag==1) return true;
        else return false;
    }
}
